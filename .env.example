# ---------------------------------------------------------------------------
# Copy to .env and fill in. docker-compose reads .env automatically.
# ---------------------------------------------------------------------------

# --- where to send the alert -----------------------------------------------
ALERT_TO=test@test.ru
ALERT_FROM=anc-watch@yourdomain.tld

# --- SMTP (REQUIRED to actually send mail; if SMTP_HOST is empty the script
#     runs in DRY-RUN mode and only logs the e-mail) ---------------------------
# pm.me (ProtonMail) has no plain SMTP, so send THROUGH any relay you control.
# Example with Gmail + App Password (https://myaccount.google.com/apppasswords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURITY=starttls
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_16_char_app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls          # starttls | ssl | none
SMTP_USER=
SMTP_PASS=

# --- what to watch ---------------------------------------------------------
ANC_DOSSIER=10225/RD/2023
ANC_ARTICLE=11
ANC_YEAR=2023

# --- behaviour -------------------------------------------------------------
CHECK_INTERVAL=86400            # seconds between checks (86400 = daily)
NOTIFY_ON_START=1               # 1 = send one baseline e-mail on first run
ALWAYS_NOTIFY=0                 # 1 = e-mail every run, not only on change
NOTIFY_ON_ERROR=1               # 1 = e-mail if the site can't be read repeatedly
LOG_LEVEL=INFO
